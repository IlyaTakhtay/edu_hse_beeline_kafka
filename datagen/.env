# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_secure_password
CLICKHOUSE_DB=default

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=beeline_db
POSTGRES_USER=beeline_user
POSTGRES_PASSWORD=beeline_password
POSTGRES_SCHEMA=user_events          # схема, в которой создавать таблицы

# Параметры генерации (непрерывный режим)
# Можно задать фиксированный размер батча (BATCH_SIZE) или диапазон (MIN/MAX)
# BATCH_SIZE=459                   # фиксированный размер (если задан, MIN/MAX игнорируются)
BATCH_SIZE_MIN=100                # минимальный размер батча (если BATCH_SIZE не задан)
BATCH_SIZE_MAX=600               # максимальный размер батча
BANNER_COUNT=35
CAMPAIGN_COUNT=10

# Интервал между итерациями: фиксированный (SLEEP_SECONDS) или диапазон (MIN/MAX)
# SLEEP_SECONDS=0.2               # фиксированный интервал (если задан, MIN/MAX игнорируются)
SLEEP_MIN=0.3                   # минимальная пауза (сек)
SLEEP_MAX=1                   # максимальная пауза (сек)

# Вероятности (остаются как есть)
CLICK_PROBABILITY=0.03
INSTALL_PROBABILITY=0.2
ORGANIC_PROBABILITY=0.01
